# Server Configuration
PORT=5000
NODE_ENV=development

# Database Configuration
# Replace with your local MongoDB connection string or MongoDB Atlas connection string
MONGO_URI=mongodb://127.0.0.1:27017/ai-crm

# Security Configurations
JWT_SECRET=super_secret_jwt_key_crm_app
JWT_EXPIRES_IN=7d

# Google Gemini API Configurations
# Required for AI response suggestions. Get a key from Google AI Studio.
GEMINI_API_KEY=
